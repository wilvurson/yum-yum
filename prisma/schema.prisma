// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model MealType {
  id    Int    @id @default(autoincrement())
  name  String @unique
  foods Food[]
}

model Food {
  id         Int      @id @default(autoincrement())
  name       String
  calories String 
  mealTypeId Int
  cuisineId Int?
  mealType   MealType @relation(fields: [mealTypeId], references: [id])
  cuisine   Cuisine? @relation(fields: [cuisineId], references: [id])
  image String
  price Decimal @db.Decimal(4,2)
}

model GroceryItem {
  id               Int    @id @default(autoincrement())
  name             String
  unit             String
  calPerUnit  String
  image            String?
  price Decimal @db.Decimal(4,2)
}

model Cuisine {
  id    Int    @id @default(autoincrement())
  name  String @unique
  food Food[]
}

model Schedule {
  id        Int      @id @default(autoincrement())
  date      DateTime
  startTime String
  endTime   String
  activity  String

  users User[]
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  isAdmin   Boolean  @default(false)
  orders    Order[]
  schedule  Schedule[]
}

model Order {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  items     String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}
