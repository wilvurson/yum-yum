generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_2IbeW8lLVoRO@ep-patient-fire-a16kscy6-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
}

model MealType {
  id    Int    @id @default(autoincrement())
  name  String @unique
  foods Food[]
}

model Food {
  id         Int      @id @default(autoincrement())
  name       String
  calories   String
  mealTypeId Int
  cuisineId  Int?
  mealType   MealType @relation(fields: [mealTypeId], references: [id])
  cuisine    Cuisine? @relation(fields: [cuisineId], references: [id])
  image      String
  price      Decimal  @db.Decimal(4, 2)
  orderItems OrderItem[]
} 

model GroceryItem {
  id         Int     @id @default(autoincrement())
  name       String
  unit       String
  calPerUnit String
  image      String?
  price      Decimal @db.Decimal(4, 2)
  orderItems OrderItem[]
}

model Cuisine {
  id   Int    @id @default(autoincrement())
  name String @unique
  food Food[]
}

model Schedule {
  id        Int      @id @default(autoincrement())
  date      DateTime
  startTime String
  endTime   String
  activity  String
  completed Boolean  @default(false)
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
}

model User {
  id             Int          @id @default(autoincrement())
  username       String?
  name           String
  email          String       @unique
  isAdmin        Boolean      @default(false)
  orders         Order[]
  schedules      Schedule[]
  streak         Int          @default(0)
  points         Int          @default(0)
  lastLoginDate  DateTime?
  streakStartDate DateTime?
  friendsSent    Friendship[] @relation("UserSent")
  friendsReceived Friendship[] @relation("UserReceived")
}

model Friendship {
  id        Int      @id @default(autoincrement())
  senderId  Int
  receiverId Int
  status    String   @default("pending") // pending, accepted, rejected
  createdAt DateTime @default(now())
  sender    User     @relation("UserSent", fields: [senderId], references: [id])
  receiver  User     @relation("UserReceived", fields: [receiverId], references: [id])

  @@unique([senderId, receiverId])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  DELIVERING
  COMPLETED
  CANCELLED
}


model Order {
  id         Int          @id @default(autoincrement())
  userId     Int
  user       User         @relation(fields: [userId], references: [id])
  status     OrderStatus  @default(PENDING)
  totalPrice Int
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  items      OrderItem[]
  @@index([userId])
}

model OrderItem {
  id        Int   @id @default(autoincrement())
  orderId  Int
  foodId Int?
  groceryItemId Int?
  quantity Int
  price    Int

  order   Order   @relation(fields: [orderId], references: [id])
  food  Food?  @relation(fields: [foodId], references: [id])
  groceryItem GroceryItem? @relation(fields: [groceryItemId], references: [id])
}